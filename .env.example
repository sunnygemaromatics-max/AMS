# ============================================================
# Asset Harmony — Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase credentials.
# NEVER commit .env or .env.production to version control.
# ============================================================

# Supabase Project URL (find in: Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anonymous/Public Key (find in: Project Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
